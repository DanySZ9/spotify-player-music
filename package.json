{
  "name": "spotify-widget-app",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "DaNYsZ99",
  "license": "ISC",
  "description": "spotify-widget-app",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.spotifywidget.desktop",
    "productName": "Spotify Widget",
    "icon": "icons/icon",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bootstrap-icons": "^1.13.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lottie-web": "^5.13.0"
  },
  "extraResources": [
    {
      "from": ".env",
      "to": ".env"
    }
  ]
}
